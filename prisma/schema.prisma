generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "sqlite"
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENTO
  VOICE
  STICKER
  LOCATION
  CONTACT
  UNKNOWN
}

model Message {
  id              String   @id @default(uuid())
  externalId      String   @unique // wa_message_id
  direction       MessageDirection
  type            MessageType
  from            String
  to              String
  chatId          String
  content         String?
  mediaUrl        String?
  mediaMimeType   String?
  mediaFileName   String?
  mediaFileSize   Int?
  mediaDuration   Int?
  isGroup         Boolean  @default(false)
  quotedMessageId String?
  timestamp       DateTime
  status          MessageStatus   @default(PENDING)
  error           String?

  // Chatwoot refs
  chatwootConversationId Int?
  chatwootMessageId      Int?
  chatwootContactId      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([externalId])
  @@index([chatwootMessageId])
  @@index([status])
  @@index([chatId, timestamp])
}

model Contact {
  id             String  @id
  phoneNumber    String  @unique
  name           String?
  pushName       String?
  profilePicture String?
  isBusiness     Boolean @default(false)
  labels         String? // JSON array

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
