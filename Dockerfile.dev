FROM node:24-alpine

# Dependências nativas + ffmpeg (necessário para áudio no Baileys)
RUN apk add --no-cache libc6-compat python3 make g++ ffmpeg curl

WORKDIR /app

# Copiar apenas arquivos de dependência para cache eficiente
COPY package.json package-lock.json* pnpm-lock.yaml* ./

# Instalar TODAS as dependências (dev + prod)
RUN npm ci --include=dev

# Copiar schema do Prisma e gerar cliente inicial
COPY prisma ./prisma
RUN npx prisma generate

# Copiar restante do código (será sobrescrito pelo bind mount em dev)
COPY . .

# Criar diretórios de dados
RUN mkdir -p /app/auth_info /app/uploads /app/data

# Entrypoint
COPY docker-entrypoint.dev.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.dev.sh

EXPOSE 3000

ENV NODE_ENV=development
ENV PORT=3000

ENTRYPOINT ["docker-entrypoint.dev.sh"]
CMD ["npx", "tsx", "watch", "src/main.ts"]
