# === Servidor ===
PORT=3000
NODE_ENV=development

# === Chatwoot ===
CHATWOOT_BASE_URL=https://seu-chatwoot.com
CHATWOOT_API_TOKEN=seu_token_aqui
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1  # Inbox API Channel que será usado

# === Webhook Security ===
WEBHOOK_SECRET=webhook_secret_para_validar_hmac

# === Baileys ===
BAILEYS_AUTH_DIR=./auth_info
BAILEYS_BROWSER_NAME=BaileysChatwootBridge

# === Media Storage ===
MEDIA_UPLOAD_DIR=./uploads
MEDIA_MAX_SIZE=50mb
MEDIA_BASE_URL=http://localhost:3000/uploads

# === Database (opcional, para metadados) ===
DATABASE_URL="file:./dev.db"  # SQLite para MVP, ou PostgreSQL